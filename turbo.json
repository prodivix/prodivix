{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": ["VITEPRESS_BASE"],
      "outputs": ["dist/**", ".vitepress/dist/**"]
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@prodivix/plugin-contracts#test": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "@prodivix/plugin-host#test": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "@prodivix/plugin-package#test": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "@prodivix/plugin-react-host#test": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "@prodivix/plugin-protocol#test": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "@prodivix/plugin-browser#test": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "storybook": {
      "cache": false,
      "persistent": true
    },
    "build-storybook": {
      "dependsOn": ["^build"],
      "outputs": ["storybook-static/**"]
    }
  }
}
