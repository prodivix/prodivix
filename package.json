{
  "name": "prodivix",
  "version": "0.1.0",
  "private": true,
  "description": "可视化前端开发平台 - 从设计到部署的全流程解决方案",
  "license": "MIT",
  "packageManager": "pnpm@10.28.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@prodivix/web",
    "dev:backend": "cd apps/backend && (air -c .air.toml || go run ./cmd/server)",
    "dev:backend:hot": "cd apps/backend && air -c .air.toml",
    "dev:docs": "turbo run dev --filter=@prodivix/docs",
    "dev:cli": "turbo run dev --filter=@prodivix/cli",
    "dev:vscode": "turbo run dev --filter=@prodivix/vscode",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@prodivix/web",
    "build:backend": "cd apps/backend && make build",
    "build:docs": "turbo run build --filter=@prodivix/docs",
    "build:cli": "turbo run build --filter=@prodivix/cli",
    "build:vscode": "turbo run build --filter=@prodivix/vscode",
    "storybook:ui": "turbo run storybook --filter=@prodivix/ui",
    "build-storybook:ui": "turbo run build-storybook --filter=@prodivix/ui",
    "test": "turbo run test",
    "test:e2e": "playwright test --config tests/e2e/playwright.config.mts",
    "test:e2e:chrome": "cross-env E2E_BROWSER_CHANNEL=chrome playwright test --config tests/e2e/playwright.config.mts",
    "test:e2e:smoke": "playwright test --config tests/e2e/playwright.config.mts --grep @smoke",
    "test:e2e:smoke:chrome": "cross-env E2E_BROWSER_CHANNEL=chrome playwright test --config tests/e2e/playwright.config.mts --grep @smoke",
    "test:web": "pnpm --filter @prodivix/web test",
    "test:web:watch": "pnpm --filter @prodivix/web test:watch",
    "test:web:coverage": "pnpm --filter @prodivix/web test:coverage",
    "lint": "turbo run lint",
    "docs:diagnostics": "node scripts/generate-diagnostic-docs.mjs generate",
    "docs:diagnostics:check": "node scripts/generate-diagnostic-docs.mjs check",
    "generate:tailwind-runtime-snapshot": "node --experimental-strip-types scripts/generate-tailwind-runtime-snapshot.mjs",
    "format": "pnpm run format:all",
    "prettier": "pnpm run format:all",
    "format:all": "pnpm run format:prettier && pnpm run format:go",
    "format:prettier": "prettier --write \"{apps,packages,specs,scripts}/**/*.{ts,tsx,js,jsx,json,md,yml,yaml,scss,css,html}\" \"*.{json,md,yml,yaml}\"",
    "format:go": "cd apps/backend && go fmt ./...",
    "clean": "turbo run clean && rm -rf node_modules",
    "cli": "node apps/cli/bin/prodivix.js",
    "prepare": "husky",
    "tw:migrate": "npx @tailwindcss/upgrade ./apps/web ./packages/ui ./packages/themes",
    "tw:migrate:check": "git diff --stat"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "cross-env": "^7.0.3",
    "husky": "^9.1.7",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.6.0",
    "typescript": "~5.9.3"
  }
}
