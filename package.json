{
  "name": "prodivix",
  "version": "0.1.0",
  "private": true,
  "description": "可视化前端开发平台 - 从设计到部署的全流程解决方案",
  "license": "MIT",
  "packageManager": "pnpm@11.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@prodivix/web",
    "dev:backend": "node scripts/start-dev-backend.mjs",
    "dev:backend:hot": "cd apps/backend && air -c .air.toml",
    "dev:docs": "turbo run dev --filter=@prodivix/docs",
    "dev:cli": "turbo run dev --filter=@prodivix/cli",
    "dev:vscode": "turbo run dev --filter=@prodivix/vscode",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@prodivix/web",
    "build:backend": "cd apps/backend && make build",
    "build:docs": "turbo run build --filter=@prodivix/docs",
    "build:cli": "turbo run build --filter=@prodivix/cli",
    "build:vscode": "turbo run build --filter=@prodivix/vscode",
    "build:packages": "turbo run build --filter=@prodivix/shared --filter=@prodivix/themes --filter=@prodivix/ui",
    "storybook:ui": "turbo run storybook --filter=@prodivix/ui",
    "build-storybook:ui": "turbo run build-storybook --filter=@prodivix/ui",
    "test": "turbo run test",
    "test:golden": "turbo run test --filter=@prodivix/golden-conformance",
    "verify:g0": "node scripts/verify-g0.mjs",
    "test:e2e": "playwright test --config tests/e2e/playwright.config.mts",
    "test:e2e:chrome": "cross-env E2E_BROWSER_CHANNEL=chrome playwright test --config tests/e2e/playwright.config.mts --project=chromium",
    "test:e2e:firefox": "playwright test --config tests/e2e/playwright.config.mts --project=firefox",
    "test:e2e:webkit": "playwright test --config tests/e2e/playwright.config.mts --project=webkit",
    "test:e2e:plugin-sandbox:matrix": "playwright test --config tests/e2e/playwright.config.mts tests/e2e/specs/plugin-sandbox.spec.ts --project=chromium --project=firefox --project=webkit --workers=3",
    "test:e2e:smoke": "playwright test --config tests/e2e/playwright.config.mts --grep @smoke",
    "test:e2e:smoke:chromium": "playwright test --config tests/e2e/playwright.config.mts --grep @smoke --project=chromium",
    "test:e2e:smoke:chrome": "cross-env E2E_BROWSER_CHANNEL=chrome playwright test --config tests/e2e/playwright.config.mts --grep @smoke --project=chromium",
    "test:web": "pnpm --filter @prodivix/web test",
    "test:web:watch": "pnpm --filter @prodivix/web test:watch",
    "test:web:coverage": "pnpm --filter @prodivix/web test:coverage",
    "lint": "turbo run lint && pnpm run check:core-boundaries && pnpm run check:editor-hard-cut && pnpm run check:pir-current-boundary && pnpm run check:property-test-names",
    "check:core-boundaries": "node scripts/check-core-package-boundaries.mjs",
    "check:editor-hard-cut": "node scripts/check-editor-hard-cut.mjs",
    "check:pir-current-boundary": "node scripts/check-pir-current-boundary.mjs",
    "check:property-test-names": "node scripts/check-property-test-names.mjs",
    "pir:sync-wire": "pnpm --filter @prodivix/shared generate:pir-wire",
    "pir:activate-wire": "node scripts/activate-pir-wire-version.mjs",
    "version:packages:patch": "node scripts/bump-packages.mjs patch",
    "version:packages:minor": "node scripts/bump-packages.mjs minor",
    "version:packages:major": "node scripts/bump-packages.mjs major",
    "publish:packages:dry-run": "pnpm run build:packages && pnpm --filter @prodivix/shared publish --dry-run --access public --no-git-checks && pnpm --filter @prodivix/themes publish --dry-run --access public --no-git-checks && pnpm --filter @prodivix/ui publish --dry-run --access public --no-git-checks",
    "publish:packages": "pnpm run build:packages && pnpm --filter @prodivix/shared publish --access public --no-git-checks && pnpm --filter @prodivix/themes publish --access public --no-git-checks && pnpm --filter @prodivix/ui publish --access public --no-git-checks",
    "release:packages:patch": "pnpm run version:packages:patch && pnpm run publish:packages",
    "release:packages:minor": "pnpm run version:packages:minor && pnpm run publish:packages",
    "release:packages:major": "pnpm run version:packages:major && pnpm run publish:packages",
    "docs:diagnostics": "node scripts/generate-diagnostic-docs.mjs generate",
    "docs:diagnostics:check": "node scripts/generate-diagnostic-docs.mjs check",
    "check:official-plugin-cutover": "node scripts/plugin-artifacts/check-official-plugin-cutover.mjs",
    "test:official-plugin-exports": "tsx --tsconfig packages/prodivix-compiler/tsconfig.json scripts/plugin-artifacts/check-official-plugin-exports.mjs",
    "test:plugin-artifact-generator": "pnpm --filter @prodivix/plugin-contracts build && pnpm --filter @prodivix/plugin-package build && node scripts/plugin-artifacts/generate-bundled-plugin-artifact.test.mjs",
    "generate:tailwind-runtime-snapshot": "node --experimental-strip-types scripts/generate-tailwind-runtime-snapshot.mjs",
    "format": "pnpm run format:all",
    "prettier": "pnpm run format:all",
    "format:all": "pnpm run format:prettier && pnpm run format:go",
    "format:prettier": "prettier --write \"{apps,packages,specs,scripts}/**/*.{ts,tsx,js,jsx,json,md,yml,yaml,scss,css,html}\" \"*.{json,md,yml,yaml}\"",
    "format:go": "cd apps/backend && go fmt ./...",
    "clean": "turbo run clean && rm -rf node_modules",
    "cli": "node apps/cli/bin/prodivix.js",
    "prepare": "husky",
    "tw:migrate": "npx @tailwindcss/upgrade ./apps/web ./packages/ui ./packages/themes",
    "tw:migrate:check": "git diff --stat"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "cross-env": "^10.1.0",
    "husky": "^9.1.7",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.10.2",
    "tsx": "^4.22.4",
    "typescript": "~6.0.3"
  }
}
