{
  "name": "@prodivix/prodivix-compiler",
  "version": "0.0.1",
  "type": "module",
  "description": "Prodivix PIR and Workspace compiler",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "imports": {
    "#src/export": {
      "types": "./dist/export/index.d.ts",
      "import": "./dist/export/index.js"
    },
    "#src/*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm run clean && tsc -b tsconfig.json",
    "clean": "node -e \"const fs=require('node:fs'); fs.rmSync('dist',{recursive:true,force:true}); fs.rmSync('tsconfig.tsbuildinfo',{force:true})\"",
    "dev": "tsc --watch",
    "test": "vitest --config vitest.config.ts --run",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "dependencies": {
    "@prodivix/animation": "workspace:*",
    "@prodivix/authoring": "workspace:*",
    "@prodivix/nodegraph": "workspace:*",
    "@prodivix/pir": "workspace:*",
    "@prodivix/router": "workspace:*",
    "@prodivix/shared": "workspace:*",
    "@prodivix/themes": "workspace:*",
    "@prodivix/ui": "workspace:*",
    "@prodivix/workspace": "workspace:*",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "fast-check": "^4.9.0",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
