{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "noEmit": true,
    "tsBuildInfoFile": "./node_modules/.cache/tsconfig.test.tsbuildinfo",
    "paths": {
      "@prodivix/animation": ["../animation/dist/index.d.ts"],
      "@prodivix/nodegraph": ["../nodegraph/dist/index.d.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"],
  "references": [
    {
      "path": "../animation"
    },
    {
      "path": "../nodegraph"
    }
  ]
}
