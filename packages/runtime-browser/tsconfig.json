{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "noEmit": false,
    "paths": {
      "@prodivix/animation": ["../animation/src"],
      "@prodivix/runtime-core": ["../runtime-core/src"],
      "@prodivix/runtime-vitest": ["../runtime-vitest/src"]
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/__tests__/**"
  ],
  "references": [
    {
      "path": "../animation"
    },
    {
      "path": "../runtime-core"
    },
    {
      "path": "../runtime-vitest"
    }
  ]
}
