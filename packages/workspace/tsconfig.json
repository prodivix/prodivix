{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "noEmit": false,
    "paths": {
      "@prodivix/animation": ["../animation/src"],
      "@prodivix/authoring": ["../authoring/src"],
      "@prodivix/nodegraph": ["../nodegraph/src"],
      "@prodivix/pir": ["../pir/src"],
      "@prodivix/router": ["../router/src"]
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/__tests__/**"
  ],
  "references": [
    {
      "path": "../animation"
    },
    {
      "path": "../authoring"
    },
    {
      "path": "../nodegraph"
    },
    {
      "path": "../pir"
    },
    {
      "path": "../router"
    }
  ]
}
