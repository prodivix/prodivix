{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "noEmit": false,
    "paths": {
      "@prodivix/animation": ["../animation/src"],
      "@prodivix/assets": ["../assets/src"],
      "@prodivix/authoring": ["../authoring/src"],
      "@prodivix/data": ["../data/src"],
      "@prodivix/diagnostics": ["../diagnostics/src"],
      "@prodivix/nodegraph": ["../nodegraph/src"],
      "@prodivix/pir": ["../pir/src"],
      "@prodivix/router": ["../router/src"],
      "@prodivix/server-runtime": ["../server-runtime/src"],
      "@prodivix/tokens": ["../tokens/src"]
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/__tests__/**"
  ],
  "references": [
    {
      "path": "../animation"
    },
    {
      "path": "../assets"
    },
    {
      "path": "../authoring"
    },
    {
      "path": "../data"
    },
    {
      "path": "../diagnostics"
    },
    {
      "path": "../nodegraph"
    },
    {
      "path": "../pir"
    },
    {
      "path": "../router"
    },
    {
      "path": "../server-runtime"
    },
    {
      "path": "../tokens"
    }
  ]
}
