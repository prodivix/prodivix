{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "types": ["node"],
    "noEmit": true,
    "paths": {
      "@prodivix/animation": ["../animation/dist/index.d.ts"],
      "@prodivix/authoring": ["../authoring/dist/index.d.ts"],
      "@prodivix/nodegraph": ["../nodegraph/dist/index.d.ts"],
      "@prodivix/pir": ["../pir/dist/index.d.ts"],
      "@prodivix/router": ["../router/dist/index.d.ts"],
      "@prodivix/tokens": ["../tokens/dist/index.d.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"],
  "references": [
    {
      "path": "../animation"
    },
    {
      "path": "../authoring"
    },
    {
      "path": "../nodegraph"
    },
    {
      "path": "../pir"
    },
    {
      "path": "../router"
    },
    {
      "path": "../tokens"
    }
  ]
}
