{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "declaration": true,
    "declarationMap": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "noEmit": false,
    "paths": {
      "@prodivix/router": ["../router/src"],
      "@prodivix/shared": ["../shared/src"],
      "@prodivix/shared/*": ["../shared/src/*"],
      "@prodivix/themes": ["../themes/src"]
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.stories.ts",
    "src/**/*.stories.tsx",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/__tests__/**"
  ],
  "references": [
    {
      "path": "../router"
    },
    {
      "path": "../shared"
    },
    {
      "path": "../themes"
    }
  ]
}
