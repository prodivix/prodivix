{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prodivix.dev/schemas/theme-manifest.schema.json",
  "title": "Prodivix Theme Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "name", "source", "mode", "semantic"],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(\\.[a-z0-9][a-z0-9-]*)+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "author": {
      "type": "string"
    },
    "source": {
      "enum": ["official", "custom", "community"]
    },
    "mode": {
      "enum": ["light", "dark", "adaptive"]
    },
    "semantic": {
      "$ref": "#/$defs/tokenTree"
    },
    "product": {
      "$ref": "#/$defs/tokenTree"
    },
    "typography": {
      "$ref": "#/$defs/tokenTree"
    },
    "radius": {
      "$ref": "#/$defs/stringMap"
    },
    "shadow": {
      "$ref": "#/$defs/stringMap"
    },
    "density": {
      "$ref": "#/$defs/tokenTree"
    },
    "motion": {
      "$ref": "#/$defs/tokenTree"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "preview": {
          "type": "string"
        },
        "license": {
          "type": "string"
        }
      }
    }
  },
  "$defs": {
    "stringMap": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "tokenTree": {
      "type": "object",
      "additionalProperties": {
        "anyOf": [
          {
            "type": "string",
            "minLength": 1
          },
          {
            "type": "number"
          },
          {
            "$ref": "#/$defs/tokenTree"
          }
        ]
      }
    }
  }
}
