{
  "name": "@prodivix/themes",
  "version": "0.0.3",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mdr-Tutorials/prodivix.git",
    "directory": "packages/themes"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./css/default.css": "./dist/css/default.css",
    "./css/font-stacks.css": "./dist/css/font-stacks.css",
    "./package.json": "./package.json",
    "./schema": "./dist/schema/themeManifest.schema.json",
    "./manifests/official/monochrome-light.json": "./manifests/official/monochrome-light.json",
    "./manifests/official/monochrome-dark.json": "./manifests/official/monochrome-dark.json",
    "./manifests/official/monochrome-light-high-contrast.json": "./manifests/official/monochrome-light-high-contrast.json",
    "./manifests/official/monochrome-dark-high-contrast.json": "./manifests/official/monochrome-dark-high-contrast.json"
  },
  "files": [
    "dist",
    "manifests"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm run clean && vite build && tsc -p tsconfig.json && node scripts/copy-assets.mjs && node scripts/write-default-css.mjs",
    "clean": "node -e \"const fs=require('node:fs'); fs.rmSync('dist',{recursive:true,force:true}); fs.rmSync('tsconfig.tsbuildinfo',{force:true})\""
  },
  "devDependencies": {
    "typescript": "~5.9.3",
    "vite": "^7.3.0"
  }
}
