{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "noEmit": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "index.ts",
    "presets/**/*.ts",
    "utils/**/*.ts",
    "src/**/*.ts",
    "src/**/*.json",
    "manifests/**/*.json"
  ],
  "exclude": ["node_modules", "dist"]
}
