{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "noEmit": false,
    "paths": {
      "#radix/*": ["./src/*"],
      "@prodivix/plugin-package": ["../plugin-package/src"],
      "@prodivix/plugin-react-host": ["../plugin-react-host/src"]
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/__tests__/**"
  ],
  "references": [
    { "path": "../plugin-package" },
    { "path": "../plugin-react-host" }
  ]
}
