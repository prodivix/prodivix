{
  "$schema": "https://prodivix.dev/schemas/blueprint-template-contribution-v1.schema.json",
  "schemaVersion": "1.0",
  "surface": "blueprint.components",
  "templates": [
    {
      "id": "radix.accordion",
      "palette": {
        "contributionId": "radix.palette",
        "itemId": "radix-accordion"
      },
      "primaryLocalId": "accordion",
      "fragment": {
        "rootLocalIds": ["accordion"],
        "nodesByLocalId": {
          "accordion": {
            "type": "RadixAccordionRoot",
            "props": {
              "type": "single",
              "defaultValue": "item-1",
              "collapsible": true
            },
            "style": {
              "width": 280,
              "border": "1px solid #d4d4d4",
              "borderRadius": 6,
              "backgroundColor": "#ffffff"
            }
          },
          "item": {
            "type": "RadixAccordionItem",
            "props": { "value": "item-1" }
          },
          "header": {
            "type": "RadixAccordionHeader",
            "style": { "margin": 0 }
          },
          "trigger": {
            "type": "RadixAccordionTrigger",
            "text": "Accordion item",
            "style": {
              "width": "100%",
              "padding": 12,
              "border": 0,
              "backgroundColor": "#f5f5f5",
              "color": "#171717",
              "fontWeight": 600,
              "textAlign": "left",
              "cursor": "pointer"
            }
          },
          "content": {
            "type": "RadixAccordionContent",
            "text": "Accordion content",
            "style": {
              "padding": 12,
              "color": "#525252"
            }
          }
        },
        "childIdsByLocalId": {
          "accordion": ["item"],
          "item": ["header", "content"],
          "header": ["trigger"],
          "trigger": [],
          "content": []
        }
      }
    },
    {
      "id": "radix.tabs",
      "palette": {
        "contributionId": "radix.palette",
        "itemId": "radix-tabs"
      },
      "primaryLocalId": "tabs",
      "fragment": {
        "rootLocalIds": ["tabs"],
        "nodesByLocalId": {
          "tabs": {
            "type": "RadixTabsRoot",
            "props": { "defaultValue": "tab-1" },
            "style": {
              "width": 300,
              "border": "1px solid #d4d4d4",
              "borderRadius": 6,
              "backgroundColor": "#ffffff"
            }
          },
          "list": {
            "type": "RadixTabsList",
            "props": { "aria-label": "Example tabs" },
            "style": {
              "display": "flex",
              "gap": 4,
              "padding": 4,
              "borderBottom": "1px solid #e5e5e5"
            }
          },
          "trigger-1": {
            "type": "RadixTabsTrigger",
            "props": { "value": "tab-1" },
            "text": "First",
            "style": {
              "padding": "6px 10px",
              "border": 0,
              "borderRadius": 4,
              "backgroundColor": "#e5e5e5",
              "cursor": "pointer"
            }
          },
          "trigger-2": {
            "type": "RadixTabsTrigger",
            "props": { "value": "tab-2" },
            "text": "Second",
            "style": {
              "padding": "6px 10px",
              "border": 0,
              "borderRadius": 4,
              "backgroundColor": "transparent",
              "cursor": "pointer"
            }
          },
          "content-1": {
            "type": "RadixTabsContent",
            "props": { "value": "tab-1" },
            "text": "First tab content",
            "style": { "padding": 12, "color": "#404040" }
          },
          "content-2": {
            "type": "RadixTabsContent",
            "props": { "value": "tab-2" },
            "text": "Second tab content",
            "style": { "padding": 12, "color": "#404040" }
          }
        },
        "childIdsByLocalId": {
          "tabs": ["list", "content-1", "content-2"],
          "list": ["trigger-1", "trigger-2"],
          "trigger-1": [],
          "trigger-2": [],
          "content-1": [],
          "content-2": []
        }
      }
    },
    {
      "id": "radix.dialog",
      "palette": {
        "contributionId": "radix.palette",
        "itemId": "radix-dialog"
      },
      "primaryLocalId": "dialog",
      "fragment": {
        "rootLocalIds": ["dialog"],
        "nodesByLocalId": {
          "dialog": {
            "type": "RadixDialogRoot",
            "props": { "defaultOpen": false, "modal": false }
          },
          "trigger": {
            "type": "RadixDialogTrigger",
            "text": "Open dialog",
            "style": {
              "padding": "8px 12px",
              "border": "1px solid #a3a3a3",
              "borderRadius": 6,
              "backgroundColor": "#ffffff",
              "cursor": "pointer"
            }
          },
          "portal": { "type": "RadixDialogPortal" },
          "overlay": {
            "type": "RadixDialogOverlay",
            "style": {
              "position": "absolute",
              "inset": 0,
              "backgroundColor": "rgba(0, 0, 0, 0.28)"
            }
          },
          "content": {
            "type": "RadixDialogContent",
            "style": {
              "position": "absolute",
              "top": "50%",
              "left": "50%",
              "width": 320,
              "padding": 20,
              "borderRadius": 6,
              "backgroundColor": "#ffffff",
              "boxShadow": "0 16px 48px rgba(0, 0, 0, 0.24)",
              "transform": "translate(-50%, -50%)"
            }
          },
          "title": {
            "type": "RadixDialogTitle",
            "text": "Dialog title",
            "style": { "fontSize": 18, "fontWeight": 600 }
          },
          "description": {
            "type": "RadixDialogDescription",
            "text": "Dialog description",
            "style": { "marginTop": 8, "color": "#525252" }
          },
          "close": {
            "type": "RadixDialogClose",
            "text": "Close",
            "style": {
              "marginTop": 16,
              "padding": "6px 10px",
              "border": "1px solid #a3a3a3",
              "borderRadius": 4,
              "backgroundColor": "#ffffff",
              "cursor": "pointer"
            }
          }
        },
        "childIdsByLocalId": {
          "dialog": ["trigger", "portal"],
          "trigger": [],
          "portal": ["overlay", "content"],
          "overlay": [],
          "content": ["title", "description", "close"],
          "title": [],
          "description": [],
          "close": []
        }
      }
    },
    {
      "id": "radix.popover",
      "palette": {
        "contributionId": "radix.palette",
        "itemId": "radix-popover"
      },
      "primaryLocalId": "popover",
      "fragment": {
        "rootLocalIds": ["popover"],
        "nodesByLocalId": {
          "popover": {
            "type": "RadixPopoverRoot",
            "props": { "defaultOpen": false, "modal": false }
          },
          "trigger": {
            "type": "RadixPopoverTrigger",
            "text": "Open popover",
            "style": {
              "padding": "8px 12px",
              "border": "1px solid #a3a3a3",
              "borderRadius": 6,
              "backgroundColor": "#ffffff",
              "cursor": "pointer"
            }
          },
          "portal": { "type": "RadixPopoverPortal" },
          "content": {
            "type": "RadixPopoverContent",
            "props": { "side": "bottom", "sideOffset": 8 },
            "text": "Popover content",
            "style": {
              "maxWidth": 240,
              "padding": 12,
              "border": "1px solid #d4d4d4",
              "borderRadius": 6,
              "backgroundColor": "#ffffff",
              "boxShadow": "0 8px 24px rgba(0, 0, 0, 0.16)"
            }
          }
        },
        "childIdsByLocalId": {
          "popover": ["trigger", "portal"],
          "trigger": [],
          "portal": ["content"],
          "content": []
        }
      }
    },
    {
      "id": "radix.tooltip",
      "palette": {
        "contributionId": "radix.palette",
        "itemId": "radix-tooltip"
      },
      "primaryLocalId": "tooltip",
      "fragment": {
        "rootLocalIds": ["provider"],
        "nodesByLocalId": {
          "provider": {
            "type": "RadixTooltipProvider",
            "props": { "delayDuration": 0, "skipDelayDuration": 0 }
          },
          "tooltip": {
            "type": "RadixTooltipRoot",
            "props": { "defaultOpen": false }
          },
          "trigger": {
            "type": "RadixTooltipTrigger",
            "text": "Hover for help",
            "style": {
              "padding": "8px 12px",
              "border": "1px solid #a3a3a3",
              "borderRadius": 6,
              "backgroundColor": "#ffffff",
              "cursor": "help"
            }
          },
          "portal": { "type": "RadixTooltipPortal" },
          "content": {
            "type": "RadixTooltipContent",
            "props": { "side": "top", "sideOffset": 6 },
            "text": "Helpful information",
            "style": {
              "padding": "5px 8px",
              "borderRadius": 4,
              "backgroundColor": "#171717",
              "color": "#ffffff",
              "fontSize": 12
            }
          },
          "arrow": {
            "type": "RadixTooltipArrow",
            "props": { "width": 10, "height": 5 },
            "style": { "fill": "#171717" }
          }
        },
        "childIdsByLocalId": {
          "provider": ["tooltip"],
          "tooltip": ["trigger", "portal"],
          "trigger": [],
          "portal": ["content"],
          "content": ["arrow"],
          "arrow": []
        }
      }
    },
    {
      "id": "radix.dropdown-menu",
      "palette": {
        "contributionId": "radix.palette",
        "itemId": "radix-dropdown-menu"
      },
      "primaryLocalId": "menu",
      "fragment": {
        "rootLocalIds": ["menu"],
        "nodesByLocalId": {
          "menu": {
            "type": "RadixDropdownMenuRoot",
            "props": { "defaultOpen": false, "modal": false }
          },
          "trigger": {
            "type": "RadixDropdownMenuTrigger",
            "text": "Open menu",
            "style": {
              "padding": "8px 12px",
              "border": "1px solid #a3a3a3",
              "borderRadius": 6,
              "backgroundColor": "#ffffff",
              "cursor": "pointer"
            }
          },
          "portal": { "type": "RadixDropdownMenuPortal" },
          "content": {
            "type": "RadixDropdownMenuContent",
            "props": { "side": "bottom", "sideOffset": 6, "loop": true },
            "style": {
              "minWidth": 180,
              "padding": 4,
              "border": "1px solid #d4d4d4",
              "borderRadius": 6,
              "backgroundColor": "#ffffff",
              "boxShadow": "0 8px 24px rgba(0, 0, 0, 0.16)"
            }
          },
          "item": {
            "type": "RadixDropdownMenuItem",
            "props": { "textValue": "Menu item" },
            "text": "Menu item",
            "style": {
              "padding": "6px 8px",
              "borderRadius": 4,
              "cursor": "pointer"
            }
          }
        },
        "childIdsByLocalId": {
          "menu": ["trigger", "portal"],
          "trigger": [],
          "portal": ["content"],
          "content": ["item"],
          "item": []
        }
      }
    },
    {
      "id": "radix.switch",
      "palette": {
        "contributionId": "radix.palette",
        "itemId": "radix-switch"
      },
      "primaryLocalId": "switch",
      "fragment": {
        "rootLocalIds": ["switch"],
        "nodesByLocalId": {
          "switch": {
            "type": "RadixSwitchRoot",
            "props": {
              "defaultChecked": false,
              "aria-label": "Toggle setting"
            },
            "style": {
              "position": "relative",
              "width": 40,
              "height": 22,
              "padding": 2,
              "border": 0,
              "borderRadius": 11,
              "backgroundColor": "#737373",
              "cursor": "pointer"
            }
          },
          "thumb": {
            "type": "RadixSwitchThumb",
            "style": {
              "display": "block",
              "width": 18,
              "height": 18,
              "borderRadius": 9,
              "backgroundColor": "#ffffff",
              "boxShadow": "0 1px 3px rgba(0, 0, 0, 0.3)"
            }
          }
        },
        "childIdsByLocalId": {
          "switch": ["thumb"],
          "thumb": []
        }
      }
    }
  ],
