{
  "name": "@prodivix/plugin-radix",
  "version": "0.1.0",
  "type": "module",
  "description": "Bundled official Radix UI component plugin for Prodivix",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "imports": {
    "#radix/*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "files": [
    "dist",
    "plugin",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "pnpm run check:generated:raw && pnpm run clean && tsc -p tsconfig.json",
    "check:generated": "pnpm --filter @prodivix/plugin-contracts build && pnpm --filter @prodivix/plugin-package build && pnpm run check:generated:raw",
    "check:generated:raw": "node ../../scripts/plugin-artifacts/generate-bundled-plugin-artifact.mjs --package-root . --check",
    "clean": "node -e \"const fs=require('node:fs'); fs.rmSync('dist',{recursive:true,force:true}); fs.rmSync('tsconfig.tsbuildinfo',{force:true}); fs.rmSync('tsconfig.test.tsbuildinfo',{force:true})\"",
    "generate": "pnpm --filter @prodivix/plugin-contracts build && pnpm --filter @prodivix/plugin-package build && node ../../scripts/plugin-artifacts/generate-bundled-plugin-artifact.mjs --package-root .",
    "test": "pnpm run check:generated:raw && pnpm run typecheck && vitest --config vitest.config.ts --run",
    "test:watch": "vitest --config vitest.config.ts",
    "typecheck": "tsc -b tsconfig.test.json --pretty false"
  },
  "dependencies": {
    "@prodivix/plugin-package": "workspace:*",
    "@prodivix/plugin-react-host": "workspace:*",
    "@radix-ui/react-accordion": "1.2.16",
    "@radix-ui/react-dialog": "1.1.19",
    "@radix-ui/react-dropdown-menu": "2.1.20",
    "@radix-ui/react-label": "2.1.11",
    "@radix-ui/react-popover": "1.1.19",
    "@radix-ui/react-separator": "1.1.11",
    "@radix-ui/react-slot": "1.3.0",
    "@radix-ui/react-switch": "1.3.3",
    "@radix-ui/react-tabs": "1.1.17",
    "@radix-ui/react-tooltip": "1.2.12"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@prodivix/plugin-contracts": "workspace:*",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
