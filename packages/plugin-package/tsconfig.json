{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "noEmit": false,
    "paths": {
      "#package/*": ["./src/*"],
      "@prodivix/plugin-contracts": ["../plugin-contracts/src"],
      "@prodivix/plugin-host": ["../plugin-host/src"]
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.test.ts",
    "src/**/__tests__/**"
  ],
  "references": [
    {
      "path": "../plugin-contracts"
    },
    {
      "path": "../plugin-host"
    }
  ]
}
