{
  "name": "@prodivix/plugin-package",
  "version": "0.0.1",
  "type": "module",
  "description": "Deterministic bundled plugin artifacts and package sources for Prodivix",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "imports": {
    "#package/*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "pnpm run clean && tsc -p tsconfig.json",
    "clean": "node -e \"const fs=require('node:fs'); fs.rmSync('dist',{recursive:true,force:true}); fs.rmSync('tsconfig.tsbuildinfo',{force:true})\"",
    "test": "pnpm run typecheck && vitest --config vitest.config.ts --run",
    "test:watch": "vitest --config vitest.config.ts",
    "typecheck": "tsc -b tsconfig.test.json --pretty false"
  },
  "dependencies": {
    "@prodivix/plugin-contracts": "workspace:*",
    "@prodivix/plugin-host": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
