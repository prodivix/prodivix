{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "paths": {
      "#package/*": ["./src/*"],
      "@prodivix/plugin-contracts": ["../plugin-contracts/dist/index.d.ts"],
      "@prodivix/plugin-host": ["../plugin-host/dist/index.d.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"],
