    "@prodivix/workspace": "workspace:*",
    "@prodivix/workspace-sync": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "fast-check": "^4.9.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
