{
  "name": "@prodivix/plugin-contracts",
  "version": "0.0.1",
  "type": "module",
  "description": "Serializable plugin contracts and manifest validation for Prodivix",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema/plugin-manifest-v1": {
      "types": "./dist/generated/pluginManifestSchema.generated.d.ts",
      "import": "./dist/generated/pluginManifestSchema.generated.js"
    },
    "./schema/plugin-manifest-v1.json": "./dist/schema/plugin-manifest-v1.schema.json",
    "./schema/palette-contribution-v1": {
      "types": "./dist/generated/paletteContributionSchema.generated.d.ts",
      "import": "./dist/generated/paletteContributionSchema.generated.js"
    },
    "./schema/palette-contribution-v1.json": "./dist/schema/palette-contribution-v1.schema.json",
    "./schema/external-library-contribution-v1": {
      "types": "./dist/generated/externalLibraryContributionSchema.generated.d.ts",
      "import": "./dist/generated/externalLibraryContributionSchema.generated.js"
    },
    "./schema/external-library-contribution-v1.json": "./dist/schema/external-library-contribution-v1.schema.json",
    "./schema/render-policy-contribution-v1": {
      "types": "./dist/generated/renderPolicyContributionSchema.generated.d.ts",
      "import": "./dist/generated/renderPolicyContributionSchema.generated.js"
    },
    "./schema/render-policy-contribution-v1.json": "./dist/schema/render-policy-contribution-v1.schema.json",
    "./schema/codegen-policy-contribution-v1": {
      "types": "./dist/generated/codegenPolicyContributionSchema.generated.d.ts",
      "import": "./dist/generated/codegenPolicyContributionSchema.generated.js"
    },
    "./schema/codegen-policy-contribution-v1.json": "./dist/schema/codegen-policy-contribution-v1.schema.json",
    "./schema/icon-provider-contribution-v1": {
      "types": "./dist/generated/iconProviderContributionSchema.generated.d.ts",
      "import": "./dist/generated/iconProviderContributionSchema.generated.js"
    },
    "./schema/icon-provider-contribution-v1.json": "./dist/schema/icon-provider-contribution-v1.schema.json",
    "./schema/blueprint-template-contribution-v1": {
      "types": "./dist/generated/blueprintTemplateContributionSchema.generated.d.ts",
      "import": "./dist/generated/blueprintTemplateContributionSchema.generated.js"
    },
    "./schema/blueprint-template-contribution-v1.json": "./dist/schema/blueprint-template-contribution-v1.schema.json",
    "./package.json": "./package.json"
  },
  "imports": {
    "#contracts/*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "pnpm run clean && pnpm run generate && tsc -p tsconfig.json && node scripts/copy-schema.mjs",
    "check:generated": "node scripts/generate-contracts.mjs --check",
    "clean": "node -e \"const fs=require('node:fs'); fs.rmSync('dist',{recursive:true,force:true}); fs.rmSync('tsconfig.tsbuildinfo',{force:true})\"",
    "generate": "node scripts/generate-contracts.mjs",
    "test": "pnpm run check:generated && vitest --config vitest.config.ts --run",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "jsonc-parser": "^3.3.1",
    "semver": "^7.7.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/semver": "^7.7.1",
    "json-schema-to-typescript": "^15.0.4",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
