{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "types": ["node"],
    "noEmit": true,
    "tsBuildInfoFile": "./node_modules/.cache/tsconfig.test.tsbuildinfo",
    "paths": {
      "@prodivix/diagnostics": ["../diagnostics/dist/index.d.ts"],
      "@prodivix/runtime-core": ["../runtime-core/dist/index.d.ts"],
      "@prodivix/server-runtime": ["../server-runtime/dist/index.d.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"],
  "references": [
    { "path": "../diagnostics" },
    { "path": "../runtime-core" },
    { "path": "../server-runtime" }
  ]
}
