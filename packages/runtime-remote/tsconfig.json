{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "noEmit": false,
    "paths": {
      "@prodivix/diagnostics": ["../diagnostics/src"],
      "@prodivix/runtime-core": ["../runtime-core/src"],
      "@prodivix/server-runtime": ["../server-runtime/src"]
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.test.ts",
    "src/**/__tests__/**"
  ],
  "references": [
    { "path": "../diagnostics" },
    { "path": "../runtime-core" },
    { "path": "../server-runtime" }
  ]
}
