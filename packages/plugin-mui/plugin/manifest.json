  "displayName": "Material UI",
  "engines": { "prodivix": ">=0.1.0 <1.0.0" },
  "id": "@prodivix/plugin-mui",
  "license": "MIT",
  "metadata": {
    "categories": ["Component libraries"],
    "tags": ["official", "components", "react", "mui"]
