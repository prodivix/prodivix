    },
    {
      "id": "mui.snackbar",
      "runtimeType": "MuiSnackbar",
      "elementPath": ["Snackbar"],
      "import": {
        "packageName": "@mui/material",
        "kind": "named",
        "imported": "Snackbar"
      },
      "children": { "mode": "none" }
    },
    {
      "id": "mui.dialog",
      "runtimeType": "MuiDialog",
      "elementPath": ["Dialog"],
      "import": {
        "packageName": "@mui/material",
        "kind": "named",
        "imported": "Dialog"
