      "children": { "mode": "none" }
    },
    {
      "id": "mui.card",
      "runtimeType": "MuiCard",
      "elementPath": ["Card"],
      "import": {
        "packageName": "@mui/material",
        "kind": "named",
        "imported": "Card"
      },
      "children": { "mode": "preserve" }
    },
    {
      "id": "mui.paper",
      "runtimeType": "MuiPaper",
