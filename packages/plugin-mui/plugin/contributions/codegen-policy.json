    {
      "id": "mui.stack",
      "runtimeType": "MuiStack",
      "elementPath": ["Stack"],
      "import": {
        "packageName": "@mui/material",
        "kind": "named",
        "imported": "Stack"
      },
      "children": { "mode": "preserve" }
    },
    {
      "id": "mui.grid",
      "runtimeType": "MuiGrid",
      "elementPath": ["Grid"],
