{
  "$schema": "https://prodivix.dev/schemas/codegen-policy-contribution-v1.schema.json",
  "schemaVersion": "1.0",
  "targetPreset": "react-vite",
  "libraryId": "mui",
  "dependencies": [
    {
      "name": "@mui/material",
      "version": "7.3.2",
      "kind": "dependency",
      "license": "MIT"
    },
    {
      "name": "@emotion/cache",
      "version": "11.14.0",
      "kind": "dependency",
      "license": "MIT"
    },
    {
      "name": "@emotion/react",
      "version": "11.14.0",
      "kind": "dependency",
      "license": "MIT"
    },
    {
      "name": "@emotion/styled",
      "version": "11.14.1",
      "kind": "dependency",
      "license": "MIT"
    }
  ],
  "rules": [
    {
      "id": "mui.button",
      "runtimeType": "MuiButton",
      "elementPath": ["Button"],
      "import": {
        "packageName": "@mui/material",
        "kind": "named",
        "imported": "Button"
      },
      "children": { "mode": "text-only" }
    },
    {
      "id": "mui.text-field",
      "runtimeType": "MuiTextField",
      "elementPath": ["TextField"],
      "import": {
        "packageName": "@mui/material",
        "kind": "named",
        "imported": "TextField"
      },
      "children": { "mode": "none" }
    },
    {
      "id": "mui.checkbox",
      "runtimeType": "MuiCheckbox",
      "elementPath": ["Checkbox"],
      "import": {
        "packageName": "@mui/material",
        "kind": "named",
        "imported": "Checkbox"
      },
      "children": { "mode": "none" }
    },
    {
      "id": "mui.radio",
      "runtimeType": "MuiRadio",
      "elementPath": ["Radio"],
      "import": {
        "packageName": "@mui/material",
        "kind": "named",
        "imported": "Radio"
      },
      "children": { "mode": "none" }
    },
    {
      "id": "mui.switch",
      "runtimeType": "MuiSwitch",
      "elementPath": ["Switch"],
      "import": {
        "packageName": "@mui/material",
        "kind": "named",
        "imported": "Switch"
      },
      "children": { "mode": "none" }
    },
    {
      "id": "mui.slider",
      "runtimeType": "MuiSlider",
