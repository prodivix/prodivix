        "packageName": "@mui/material",
        "kind": "named",
        "imported": "CircularProgress"
      },
      "children": { "mode": "none" }
    }
  ],
  "unsupported": {
    "behavior": "warning",
    "message": "This Material UI runtime type is not part of the official support matrix."
  }
}
