        "packageName": "@mui/material",
        "kind": "named",
        "imported": "Grid"
      },
      "children": { "mode": "preserve" }
    },
    {
      "id": "mui.container",
      "runtimeType": "MuiContainer",
      "elementPath": ["Container"],
