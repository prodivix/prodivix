{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["node"],
    "noEmit": true,
    "tsBuildInfoFile": "./node_modules/.cache/tsconfig.test.tsbuildinfo",
    "paths": {
      "@prodivix/pir": ["../pir/dist/index.d.ts"],
      "@prodivix/router": ["../router/dist/index.d.ts"],
      "@prodivix/shared": ["../shared/dist/index.d.ts"],
      "@prodivix/shared/*": ["../shared/dist/*"],
      "@prodivix/ui": ["../ui/dist/index.d.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"],
  "references": [
    { "path": "../router" },
    { "path": "../shared" },
    { "path": "../pir" },
    { "path": "../ui" }
  ]
}
