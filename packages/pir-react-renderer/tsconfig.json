{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "noEmit": false,
    "paths": {
      "@prodivix/pir": ["../pir/src"],
      "@prodivix/router": ["../router/src"],
      "@prodivix/shared": ["../shared/src"],
      "@prodivix/shared/*": ["../shared/src/*"],
      "@prodivix/ui": ["../ui/src"]
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/__tests__/**"
  ],
  "references": [
    { "path": "../router" },
    { "path": "../shared" },
    { "path": "../pir" },
    { "path": "../ui" }
  ]
}
