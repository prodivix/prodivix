{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src",
    "jsx": "react-jsx",
    "tsBuildInfoFile": "tsconfig.tsbuildinfo",
    "paths": {
      "#antd/*": ["./src/*"],
      "@prodivix/plugin-package": ["../plugin-package/src"],
      "@prodivix/plugin-react-host": ["../plugin-react-host/src"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/__tests__/**"
  ],
  "references": [
    { "path": "../plugin-package" },
    { "path": "../plugin-react-host" }
  ]
}
