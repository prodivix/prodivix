{
  "name": "@prodivix/shared",
  "version": "0.1.2",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mdr-Tutorials/prodivix.git",
    "directory": "packages/shared"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./safety": {
      "types": "./dist/safety/index.d.ts",
      "import": "./dist/safety/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "scripts"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm run clean && tsc -p tsconfig.json",
    "clean": "node -e \"const fs=require('node:fs'); fs.rmSync('dist',{recursive:true,force:true}); fs.rmSync('tsconfig.tsbuildinfo',{force:true})\"",
    "generate:pir-wire": "node scripts/sync-current-pir-schema.js && node scripts/generate-types.js"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "json-schema-to-typescript": "^15.0.4",
    "typescript": "~6.0.3"
  },
  "peerDependencies": {
    "react": "^19.1.1"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "chalk": "^5.6.2"
  }
}
