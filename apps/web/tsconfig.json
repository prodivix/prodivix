{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "@/*": ["./src/*"],
      "@prodivix/ai": ["../../packages/ai/src"],
      "@prodivix/i18n": ["../../packages/i18n/src"],
      "@prodivix/plugin-browser": ["../../packages/plugin-browser/src"],
      "@prodivix/plugin-antd": ["../../packages/plugin-antd/src"],
      "@prodivix/plugin-contracts": ["../../packages/plugin-contracts/src"],
      "@prodivix/plugin-host": ["../../packages/plugin-host/src"],
      "@prodivix/plugin-mui": ["../../packages/plugin-mui/src"],
      "@prodivix/plugin-package": ["../../packages/plugin-package/src"],
      "@prodivix/plugin-protocol": ["../../packages/plugin-protocol/src"],
      "@prodivix/plugin-radix": ["../../packages/plugin-radix/src"],
      "@prodivix/plugin-react-host": ["../../packages/plugin-react-host/src"],
      "@prodivix/prodivix-compiler": ["../../packages/prodivix-compiler/src"],
      "@prodivix/shared": ["../../packages/shared/src"],
      "@prodivix/shared/package.json": ["../../packages/shared/package.json"],
      "@prodivix/shared/*": ["../../packages/shared/src/*"],
      "@prodivix/themes": ["../../packages/themes/src"],
      "@prodivix/themes/package.json": ["../../packages/themes/package.json"],
      "@prodivix/ui": ["../../packages/ui/src"],
      "@prodivix/ui/package.json": ["../../packages/ui/package.json"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"],
  "references": [
    {
      "path": "../../packages/shared"
    },
    {
      "path": "../../packages/ai"
    },
    {
      "path": "../../packages/i18n"
    },
    {
      "path": "../../packages/plugin-contracts"
    },
    {
      "path": "../../packages/plugin-antd"
    },
    {
      "path": "../../packages/plugin-mui"
    },
    {
      "path": "../../packages/plugin-radix"
    },
    {
      "path": "../../packages/plugin-protocol"
    },
    {
      "path": "../../packages/plugin-host"
    },
    {
      "path": "../../packages/plugin-package"
    },
    {
      "path": "../../packages/plugin-react-host"
    },
    {
      "path": "../../packages/plugin-browser"
    },
    {
      "path": "../../packages/prodivix-compiler"
    },
    {
      "path": "../../packages/ui"
    },
    {
      "path": "../../packages/themes"
    }
  ]
}
