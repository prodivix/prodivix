{
  "name": "@prodivix/web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "tailwind:snapshot": "node --experimental-strip-types ../../scripts/generate-tailwind-runtime-snapshot.mjs",
    "test": "pnpm run typecheck && vitest --config vitest.config.ts --run",
