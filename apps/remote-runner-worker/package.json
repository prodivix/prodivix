{
  "name": "@prodivix/remote-runner-worker",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "pnpm run clean && tsc -p tsconfig.json",
    "clean": "node -e \"const fs=require('node:fs'); fs.rmSync('dist',{recursive:true,force:true}); fs.rmSync('tsconfig.tsbuildinfo',{force:true})\"",
    "dev": "tsx src/main.ts",
    "start": "node dist/main.js",
    "test": "pnpm run typecheck && vitest --config vitest.config.ts --run",
    "test:rootless-gate": "tsx scripts/verify-rootless-sandbox.ts",
    "typecheck": "tsc -b tsconfig.test.json --pretty false"
  },
  "dependencies": {
    "@prodivix/runtime-core": "workspace:*",
    "@prodivix/runtime-remote": "workspace:*",
    "@prodivix/runtime-vitest": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
