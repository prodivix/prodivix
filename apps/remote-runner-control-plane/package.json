{
  "name": "@prodivix/remote-runner-control-plane",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "pnpm run clean && tsc -p tsconfig.json",
    "clean": "node -e \"const fs=require('node:fs'); fs.rmSync('dist',{recursive:true,force:true}); fs.rmSync('tsconfig.tsbuildinfo',{force:true})\"",
    "dev": "tsx src/main.ts",
    "regional-recovery": "tsx src/regionalRecoveryOperatorMain.ts",
    "start": "node dist/main.js",
    "start:regional-recovery": "node dist/regionalRecoveryOperatorMain.js",
    "test": "pnpm run typecheck && vitest --config vitest.config.ts --run",
    "test:aws-kms-gate": "vitest --config vitest.config.ts --run src/terminalStateAwsKms.live.test.ts",
    "test:regional-dr": "pnpm run typecheck && vitest --config vitest.config.ts --run src/regionalConfiguration.test.ts src/regionalRecoveryOperatorConfiguration.test.ts src/regionalRecoveryOperatorJob.test.ts src/regionalRecoverySignedProof.test.ts src/regionalRecovery.integration.test.ts",
    "typecheck": "tsc -b tsconfig.test.json --pretty false"
  },
  "dependencies": {
    "@aws-sdk/client-kms": "^3.1090.0",
    "@prodivix/runtime-core": "workspace:*",
    "@prodivix/runtime-remote": "workspace:*",
    "@prodivix/runtime-remote-postgres": "workspace:*",
    "@prodivix/server-runtime": "workspace:*",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/pg": "^8.15.5",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
