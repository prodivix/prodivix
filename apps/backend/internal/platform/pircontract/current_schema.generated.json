{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prodivix.dev/schemas/pir/v1.4.json",
  "title": "Prodivix PIR Document v1.4",
  "$ref": "#/$defs/pirDocument",
  "$defs": {
    "jsonValue": {
      "anyOf": [
        { "type": "null" },
        { "type": "boolean" },
        { "type": "number" },
        { "type": "string" },
        {
          "type": "array",
          "items": { "$ref": "#/$defs/jsonValue" }
        },
        {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/jsonValue" }
        }
      ]
    },
    "sourceSpan": {
      "type": "object",
      "required": [
        "artifactId",
        "startLine",
        "startColumn",
        "endLine",
        "endColumn"
      ],
      "properties": {
        "artifactId": { "type": "string" },
        "startLine": { "type": "number" },
        "startColumn": { "type": "number" },
        "endLine": { "type": "number" },
        "endColumn": { "type": "number" }
      },
      "additionalProperties": false
    },
    "codeReference": {
      "type": "object",
      "required": ["artifactId"],
      "properties": {
        "artifactId": { "type": "string" },
        "exportName": { "type": "string" },
        "symbolId": { "type": "string" },
        "sourceSpan": { "$ref": "#/$defs/sourceSpan" }
      },
      "additionalProperties": false
    },
    "triggerBinding": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "href"],
          "properties": {
            "kind": { "const": "open-url" },
            "href": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "routeId"],
          "properties": {
            "kind": { "const": "navigate-route" },
            "routeId": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "documentId"],
          "properties": {
            "kind": { "const": "run-nodegraph" },
            "documentId": { "type": "string" },
            "inputMapping": {}
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "documentId", "timelineId", "command"],
          "properties": {
            "kind": { "const": "play-animation" },
            "documentId": { "type": "string" },
            "timelineId": { "type": "string" },
            "command": {
              "type": "string",
              "enum": ["play", "pause", "seek"]
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "slotId", "reference"],
          "properties": {
            "kind": { "const": "call-code" },
            "slotId": { "type": "string" },
            "reference": { "$ref": "#/$defs/codeReference" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "memberId"],
          "properties": {
            "kind": { "const": "emit-component-event" },
            "memberId": { "type": "string" },
            "payload": { "$ref": "#/$defs/pirValueBinding" }
          },
          "additionalProperties": false
        }
      ]
    },
    "pirValueBinding": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "value"],
          "properties": {
            "kind": { "const": "literal" },
            "value": { "$ref": "#/$defs/jsonValue" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "paramId"],
          "properties": {
            "kind": { "const": "param" },
            "paramId": { "type": "string" },
            "path": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "stateId"],
          "properties": {
            "kind": { "const": "state" },
            "stateId": { "type": "string" },
            "path": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "dataId"],
          "properties": {
            "kind": { "const": "data" },
            "dataId": { "type": "string" },
            "path": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "symbolId"],
          "properties": {
            "kind": { "const": "collection-symbol" },
            "symbolId": { "type": "string" },
            "path": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "memberId"],
          "properties": {
            "kind": { "const": "component-prop" },
            "memberId": { "type": "string" },
            "path": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "memberId"],
          "properties": {
            "kind": { "const": "component-variant" },
            "memberId": { "type": "string" },
            "path": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "memberId"],
          "properties": {
            "kind": { "const": "slot-prop" },
            "memberId": { "type": "string" },
            "path": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "reference"],
          "properties": {
            "kind": { "const": "code" },
            "reference": { "$ref": "#/$defs/codeReference" }
          },
          "additionalProperties": false
        }
      ]
    },
    "componentPropContract": {
      "type": "object",
      "required": ["id", "name", "typeRef"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "typeRef": { "type": "string" },
        "required": { "type": "boolean" },
        "defaultValue": { "$ref": "#/$defs/jsonValue" },
        "capabilityIds": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "componentEventContract": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "payloadTypeRef": { "type": "string" },
        "capabilityIds": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "componentSlotContract": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "minChildren": { "type": "number" },
        "maxChildren": { "type": "number" },
        "capabilityIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "propsById": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/componentPropContract"
          }
        }
      },
      "additionalProperties": false
    },
    "componentVariantOption": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "additionalProperties": false
    },
    "componentVariantContract": {
      "type": "object",
      "required": ["id", "name", "optionsById"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "required": { "type": "boolean" },
        "defaultOptionId": { "type": "string" },
        "optionsById": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/componentVariantOption"
          }
        }
      },
      "additionalProperties": false
    },
    "componentPartContract": {
      "type": "object",
      "required": ["id", "name", "targetNodeId"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "targetNodeId": { "type": "string" },
        "capabilityIds": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "componentTokenTarget": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "memberId"],
          "properties": {
            "kind": { "const": "prop" },
            "memberId": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "memberId"],
          "properties": {
            "kind": { "const": "part" },
            "memberId": { "type": "string" }
          },
          "additionalProperties": false
        }
      ]
    },
    "componentTokenContract": {
      "type": "object",
      "required": ["id", "tokenPath", "target"],
      "properties": {
        "id": { "type": "string" },
        "tokenPath": { "type": "string" },
        "target": { "$ref": "#/$defs/componentTokenTarget" },
        "required": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "componentAccessibilityContract": {
      "type": "object",
      "properties": {
        "requiredRole": { "type": "string" },
        "requiresAccessibleName": { "type": "boolean" },
        "description": { "type": "string" }
      },
      "additionalProperties": false
    },
    "componentContract": {
      "type": "object",
      "required": ["propsById", "eventsById", "slotsById", "variantAxesById"],
      "properties": {
        "propsById": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/componentPropContract"
          }
        },
        "eventsById": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/componentEventContract"
          }
        },
        "slotsById": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/componentSlotContract"
          }
        },
        "variantAxesById": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/componentVariantContract"
          }
        },
        "partsById": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/componentPartContract"
          }
        },
        "tokenBindings": {
          "type": "array",
          "items": { "$ref": "#/$defs/componentTokenContract" }
        },
        "accessibility": {
          "$ref": "#/$defs/componentAccessibilityContract"
        }
      },
      "additionalProperties": false
    },
    "dataScope": {
      "type": "object",
      "properties": {
        "source": { "$ref": "#/$defs/pirValueBinding" },
        "pick": { "type": "string" },
        "value": { "$ref": "#/$defs/pirValueBinding" },
        "mock": { "$ref": "#/$defs/pirValueBinding" },
        "extend": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/pirValueBinding" }
        }
      },
      "additionalProperties": false
    },
    "elementNode": {
      "type": "object",
      "required": ["id", "kind", "type"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "const": "element" },
        "type": { "type": "string" },
        "text": { "$ref": "#/$defs/pirValueBinding" },
        "style": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/pirValueBinding" }
        },
        "props": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/pirValueBinding" }
        },
        "data": { "$ref": "#/$defs/dataScope" },
        "events": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/triggerBinding" }
        }
      },
      "additionalProperties": false
    },
    "componentInstanceBindings": {
      "type": "object",
      "required": ["props", "events", "variants"],
      "properties": {
        "props": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/pirValueBinding" }
        },
        "events": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/triggerBinding" }
        },
        "variants": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "componentInstanceNode": {
      "type": "object",
      "required": ["id", "kind", "componentDocumentId", "bindings"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "const": "component-instance" },
        "componentDocumentId": { "type": "string" },
        "bindings": { "$ref": "#/$defs/componentInstanceBindings" }
      },
      "additionalProperties": false
    },
    "componentSlotOutletNode": {
      "type": "object",
      "required": ["id", "kind", "slotMemberId", "bindings"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "const": "component-slot-outlet" },
        "slotMemberId": { "type": "string" },
        "bindings": {
          "type": "object",
          "required": ["props"],
          "properties": {
            "props": {
              "type": "object",
              "additionalProperties": {
                "$ref": "#/$defs/pirValueBinding"
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "collectionSourceBinding": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "value"],
          "properties": {
            "kind": { "const": "literal" },
            "value": {
              "type": "array",
              "items": { "$ref": "#/$defs/jsonValue" }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "value"],
          "properties": {
            "kind": { "const": "binding" },
            "value": { "$ref": "#/$defs/pirValueBinding" }
          },
          "additionalProperties": false
        }
      ]
    },
    "collectionKeyBinding": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "value"],
          "properties": {
            "kind": { "const": "binding" },
            "value": { "$ref": "#/$defs/pirValueBinding" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind"],
          "properties": {
            "kind": { "const": "index" }
          },
          "additionalProperties": false
        }
      ]
    },
    "collectionSymbols": {
      "type": "object",
      "required": ["itemId", "itemName", "indexId", "indexName"],
      "properties": {
        "itemId": { "type": "string" },
        "itemName": { "type": "string" },
        "indexId": { "type": "string" },
        "indexName": { "type": "string" },
        "errorId": { "type": "string" }
      },
      "additionalProperties": false
    },
    "collectionNode": {
      "type": "object",
      "required": ["id", "kind", "source", "key", "symbols"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "const": "collection" },
        "source": { "$ref": "#/$defs/collectionSourceBinding" },
        "key": { "$ref": "#/$defs/collectionKeyBinding" },
        "symbols": { "$ref": "#/$defs/collectionSymbols" }
      },
      "additionalProperties": false
    },
    "pirNode": {
      "oneOf": [
        { "$ref": "#/$defs/elementNode" },
        { "$ref": "#/$defs/componentInstanceNode" },
        { "$ref": "#/$defs/componentSlotOutletNode" },
        { "$ref": "#/$defs/collectionNode" }
      ]
    },
    "nodeIdArray": {
      "type": "array",
      "items": { "type": "string" }
    },
    "regionMap": {
      "type": "object",
      "description": "Named node regions. Collection owners use item, empty, loading, and error regions; Component Instance owners use stable slot member ids.",
      "additionalProperties": { "$ref": "#/$defs/nodeIdArray" }
    },
    "uiGraph": {
      "type": "object",
      "required": ["version", "rootId", "nodesById", "childIdsById"],
      "properties": {
        "version": { "const": 1 },
        "rootId": { "type": "string" },
        "nodesById": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/pirNode" }
        },
        "childIdsById": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/nodeIdArray" }
        },
        "regionsById": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/regionMap" }
        },
        "order": {
          "type": "object",
          "required": ["strategy"],
          "properties": {
            "strategy": { "const": "childIdsById" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "logicPropDefinition": {
      "type": "object",
      "required": ["typeRef"],
      "properties": {
        "name": { "type": "string" },
        "typeRef": { "type": "string" },
        "description": { "type": "string" },
        "defaultValue": { "$ref": "#/$defs/jsonValue" }
      },
      "additionalProperties": false
    },
    "logicStateDefinition": {
      "type": "object",
      "required": ["initial"],
      "properties": {
        "name": { "type": "string" },
        "typeRef": { "type": "string" },
        "initial": { "$ref": "#/$defs/jsonValue" }
      },
      "additionalProperties": false
    },
    "logicDefinition": {
      "type": "object",
      "properties": {
        "props": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/logicPropDefinition" }
        },
        "state": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/logicStateDefinition"
          }
        }
      },
      "additionalProperties": false
    },
    "metadata": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "author": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "additionalProperties": false
    },
    "pirDocument": {
      "type": "object",
      "required": ["version", "ui"],
      "properties": {
        "version": { "const": "1.4" },
        "metadata": { "$ref": "#/$defs/metadata" },
        "componentContract": { "$ref": "#/$defs/componentContract" },
        "ui": {
          "type": "object",
          "required": ["graph"],
          "properties": {
            "graph": { "$ref": "#/$defs/uiGraph" }
          },
          "additionalProperties": false
        },
        "logic": { "$ref": "#/$defs/logicDefinition" }
      },
      "additionalProperties": false
    }
  }
}
